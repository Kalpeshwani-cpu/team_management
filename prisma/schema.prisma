// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  firstName       String?
  lastName        String?
  password        String?
  departmentId    String?
  isActive        Boolean   @default(true)
  approvalStatus  String    @default("pending") // pending, approved, rejected
  approvedBy      String?
  approvedAt      DateTime?
  requestedRole   String?
  walletAddress   String?   @unique @map("wallet_address")

  accounts        Account[]
  sessions        Session[]
  nonces          Nonce[]
  
  department      Department? @relation(fields: [departmentId], references: [id])
  ownedProjects   Project[]   @relation("ProjectOwner")
  projectMemberships ProjectTeamMember[]
  createdTasks    Task[]      @relation("TaskCreator")
  assignedTasks   Task[]      @relation("TaskAssignee")
  roles           UserRole[]
  activityLogs    MonitoringLog[]
  roleRequests    RoleRequest[] @relation("UserRoleRequest")
  reviewedRoleRequests RoleRequest[] @relation("RoleRequestReviewer")
  historyLogs     TaskHistory[] @relation("HistoryUser")
  notifications   Notification[]
  reviewedComplianceReports ComplianceReport[] @relation("ComplianceReviewer")
  featureVectors  UserFeatureVector?
  taskComments    TaskComment[]
  userQualifications UserQualification[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  users       User[]
  projects    Project[]
}

model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  ownerId      String
  departmentId String?
  status       String   @default("planning")
  createdAt    DateTime @default(now())
  endDate      DateTime?

  owner        User                @relation("ProjectOwner", fields: [ownerId], references: [id])
  department   Department?         @relation(fields: [departmentId], references: [id])
  teamMembers  ProjectTeamMember[]
  tasks        Task[]
  complianceReports ComplianceReport[]
}

model ProjectTeamMember {
  id        String @id @default(cuid())
  projectId String
  userId    String
  role      String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  description    String?
  priority       String   @default("medium")
  status         String   @default("todo")
  createdBy      String
  assignedTo     String?
  estimatedHours Float?   @map("estimated_hours")
  actualHours    Float?   @map("actual_hours")
  dueDate        DateTime? @map("due_date")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @map("updated_at")

  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator        User    @relation("TaskCreator", fields: [createdBy], references: [id])
  assignee       User?   @relation("TaskAssignee", fields: [assignedTo], references: [id])
  history        TaskHistory[] @relation("HistoryTask")
  comments       TaskComment[]
  recommendation MLRecommendation?
  featureVector  TaskFeatureVector?
}

model TaskComment {
  id            String   @id @default(cuid())
  taskId        String   @map("task_id")
  userId        String   @map("user_id")
  content       String
  attachmentUrl String?  @map("attachment_url")
  createdAt     DateTime @default(now()) @map("created_at")

  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model UserQualification {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  qualificationId String   @map("qualification_id")
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@unique([userId, qualificationId])
  @@map("user_qualifications")
}

model PerformanceMetric {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  metricType  String   @map("metric_type")
  metricValue Float    @map("metric_value")
  period      String
  metricDate  DateTime @map("metric_date")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("performance_metrics")
}

model ComplianceReport {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  complianceType String   @map("compliance_type")
  status         String
  score          Float
  findings       String?
  recommendations String?
  reviewedBy     String?  @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  generatedAt    DateTime @default(now()) @map("generated_at")

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer       User?    @relation("ComplianceReviewer", fields: [reviewedBy], references: [id])


  @@map("compliance_reports")
}

model UserFeatureVector {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @unique
  features  Json
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_feature_vectors")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  users       UserRole[]
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Qualification {
  id          String   @id @default(cuid())
  name        String
  description String?
  level       String?
  users       UserQualification[]
}

model MonitoringLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model RoleRequest {
  id                String    @id @default(cuid())
  userId            String
  requestedRole     String
  reasonForRequest  String?
  status            String    @default("pending")
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())

  user              User      @relation("UserRoleRequest", fields: [userId], references: [id])
  reviewer          User?     @relation("RoleRequestReviewer", fields: [reviewedBy], references: [id])
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  action    String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  changedBy String   @map("changed_by")
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation("HistoryTask", fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("HistoryUser", fields: [changedBy], references: [id])

  @@map("task_history")
}

model Notification {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  title             String
  message           String
  notificationType  String   @map("notification_type")
  relatedEntityType String?  @map("related_entity_type")
  relatedEntityId   String?  @map("related_entity_id")
  readStatus        Boolean  @default(false) @map("read_status")
  createdAt         DateTime @default(now()) @map("created_at")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Cache {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("cache")
}

model MLRecommendation {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id") @unique
  scores    Json
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("ml_recommendations")
}

model Prediction {
  id        String   @id @default(cuid())
  type      String
  entityId  String   @map("entity_id")
  result    Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("predictions")
}

model TaskFeatureVector {
  id                    String   @id @default(cuid())
  taskId                String   @map("task_id") @unique
  featureVector         Json     @map("feature_vector")
  complexityScore       Float    @map("complexity_score")
  requiredSkills        String[] @map("required_skills")
  requiredQualifications String[] @map("required_qualifications")
  teamSizeRequirement   Int      @default(1) @map("team_size_requirement")
  updatedAt             DateTime @updatedAt @map("updated_at")

  task                  Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_feature_vectors")
}

model Nonce {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  value     String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nonces")
}




